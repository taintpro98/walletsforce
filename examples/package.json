{
  "name": "walletsforce-examples",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone TypeScript project demonstrating walletsforce, linked to the local build via file:..",
  "scripts": {
    "basic": "tsx basic.ts",
    "durable": "tsx durable.ts",
    "contract-call": "tsx contract-call.ts",
    "local": "tsx local.ts",
    "funder": "tsx funder.ts",
    "profile": "node --expose-gc --import tsx profile.ts",
    "profile:cpu": "node --cpu-prof --cpu-prof-dir=./profiles --expose-gc --import tsx profile.ts",
    "testnet": "tsx testnet.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "walletsforce": "file:.."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
