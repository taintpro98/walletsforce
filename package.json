{
  "name": "walletsforce",
  "version": "0.3.1",
  "description": "General-purpose in-memory EVM account pool: route, nonce-lane, sign, broadcast, confirm, and replace transactions across many signer addresses.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taintpro98/walletsforce.git"
  },
  "homepage": "https://github.com/taintpro98/walletsforce#readme",
  "bugs": {
    "url": "https://github.com/taintpro98/walletsforce/issues"
  },
  "keywords": [
    "evm",
    "ethereum",
    "viem",
    "nonce",
    "account-pool",
    "transaction",
    "signer",
    "web3",
    "blockchain"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "viem": "^2.54.0",
    "vitest": "^2.1.0"
  }
}
